// ArtMind — Prisma schema
// Datasource: MySQL. Run `npx prisma migrate dev` to apply.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

model User {
  id            Int       @id @default(autoincrement())
  email         String    @unique
  passwordHash  String    @map("password_hash")
  name          String
  avatarUrl     String?   @map("avatar_url")
  bio           String?   @db.Text
  role          Role      @default(USER)
  refreshToken  String?   @map("refresh_token") @db.Text
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  favorites     Favorite[]
  viewHistory   ViewHistory[]
  recommendations Recommendation[]
  chatLogs      ChatLog[]
  uploadedImages UploadedImage[]
  uploads       Painting[] @relation("UserUploads")
  collections   Collection[]

  @@map("users")
}

model Artist {
  id          Int        @id @default(autoincrement())
  name        String
  slug        String     @unique
  nationality String?
  bornYear    Int?       @map("born_year")
  diedYear    Int?       @map("died_year")
  bio         String?    @db.Text
  portraitUrl String?    @map("portrait_url")
  createdAt   DateTime   @default(now()) @map("created_at")

  paintings   Painting[]

  @@map("artists")
}

model Category {
  id         Int        @id @default(autoincrement())
  name       String     @unique
  slug       String     @unique
  paintings  Painting[]

  @@map("categories")
}

model Style {
  id         Int        @id @default(autoincrement())
  name       String     @unique
  slug       String     @unique
  paintings  Painting[]

  @@map("styles")
}

model Painting {
  id            Int       @id @default(autoincrement())
  title         String
  slug          String    @unique
  description   String    @db.Text
  imageUrl      String    @map("image_url")
  thumbnailUrl  String?   @map("thumbnail_url")
  medium        String?
  surface       String?   // surface / support material e.g. canvas, panel
  dominantColors Json?    @map("dominant_colors") // ["#1e3a5f", ...]
  widthCm       Float?    @map("width_cm")
  heightCm      Float?    @map("height_cm")
  year          Int?
  price         Decimal?  @db.Decimal(12, 2)
  viewCount     Int       @default(0) @map("view_count")
  trendingScore Float     @default(0) @map("trending_score")
  aiSummary     String?   @map("ai_summary") @db.Text
  featured      Boolean   @default(false)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  artistId      Int       @map("artist_id")
  artist        Artist    @relation(fields: [artistId], references: [id])
  categoryId    Int       @map("category_id")
  category      Category  @relation(fields: [categoryId], references: [id])
  styleId       Int?      @map("style_id")
  style         Style?    @relation(fields: [styleId], references: [id])
  uploadedById  Int?      @map("uploaded_by_id")
  uploadedBy    User?     @relation("UserUploads", fields: [uploadedById], references: [id])

  favorites     Favorite[]
  viewHistory   ViewHistory[]
  recommendations Recommendation[]
  collectionItems CollectionItem[]

  @@index([categoryId])
  @@index([styleId])
  @@index([artistId])
  @@index([uploadedById])
  @@index([trendingScore])
  @@map("paintings")
}

model Favorite {
  id          Int       @id @default(autoincrement())
  userId      Int       @map("user_id")
  paintingId  Int       @map("painting_id")
  createdAt   DateTime  @default(now()) @map("created_at")

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  painting    Painting  @relation(fields: [paintingId], references: [id], onDelete: Cascade)

  @@unique([userId, paintingId])
  @@map("favorites")
}

model ViewHistory {
  id          Int       @id @default(autoincrement())
  userId      Int       @map("user_id")
  paintingId  Int       @map("painting_id")
  viewedAt    DateTime  @default(now()) @map("viewed_at")

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  painting    Painting  @relation(fields: [paintingId], references: [id], onDelete: Cascade)

  @@index([userId, viewedAt])
  @@map("view_history")
}

model Recommendation {
  id          Int       @id @default(autoincrement())
  userId      Int       @map("user_id")
  paintingId  Int       @map("painting_id")
  score       Float
  reason      String?
  createdAt   DateTime  @default(now()) @map("created_at")

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  painting    Painting  @relation(fields: [paintingId], references: [id], onDelete: Cascade)

  @@unique([userId, paintingId])
  @@map("recommendations")
}

model Collection {
  id          Int       @id @default(autoincrement())
  userId      Int       @map("user_id")
  name        String
  description String?   @db.Text
  createdAt   DateTime  @default(now()) @map("created_at")

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       CollectionItem[]

  @@map("collections")
}

model CollectionItem {
  id           Int       @id @default(autoincrement())
  collectionId Int       @map("collection_id")
  paintingId   Int       @map("painting_id")

  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  painting     Painting   @relation(fields: [paintingId], references: [id], onDelete: Cascade)

  @@unique([collectionId, paintingId])
  @@map("collection_items")
}

model ChatLog {
  id          Int       @id @default(autoincrement())
  userId      Int?      @map("user_id")
  prompt      String    @db.Text
  response    String    @db.Text
  tokensUsed  Int?      @map("tokens_used")
  createdAt   DateTime  @default(now()) @map("created_at")

  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("chat_logs")
}

model UploadedImage {
  id            Int       @id @default(autoincrement())
  userId        Int?      @map("user_id")
  imageUrl      String    @map("image_url")
  detectedStyle String?   @map("detected_style")
  detectedCategory String? @map("detected_category")
  dominantColors Json?    @map("dominant_colors")
  confidence    Float?
  createdAt     DateTime  @default(now()) @map("created_at")

  user          User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("uploaded_images")
}

model Analytics {
  id          Int       @id @default(autoincrement())
  metric      String    // e.g. "page_view", "search", "recognition"
  entityType  String?   @map("entity_type")
  entityId    Int?      @map("entity_id")
  value       Float     @default(1)
  metadata    Json?
  recordedAt  DateTime  @default(now()) @map("recorded_at")

  @@index([metric, recordedAt])
  @@map("analytics")
}
